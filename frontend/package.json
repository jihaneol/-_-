{
  "name": "card-service-frontends",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "admin",
    "shop",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev:admin",
    "dev:admin": "npm --workspace @card-service/admin-frontend run dev",
    "dev:shop": "npm --workspace @card-service/shop-frontend run dev",
    "build": "rm -rf dist && npm run build:admin && npm run build:shop",
    "build:admin": "npm --workspace @card-service/admin-frontend run build",
    "build:shop": "npm --workspace @card-service/shop-frontend run build",
    "test": "vitest --config vitest.config.ts"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^26.1.0",
    "msw": "^2.12.3",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
